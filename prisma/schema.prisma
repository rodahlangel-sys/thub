generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARENT
  TUTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CertificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TutorDocumentType {
  STUDENT_CARD
  ENROLLMENT_PROOF
  CERTIFICATE
  OTHER
}

enum TutorDocumentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum DemandStatus {
  OPEN
  MATCHED
  CLOSED
}

enum OrderStatus {
  PENDING_TUTOR_CONFIRM
  PENDING_PAYMENT
  ESCROWED
  IN_PROGRESS
  PENDING_PARENT_CONFIRM
  COMPLETED
  REFUND_REQUESTED
  REFUNDED
  CANCELLED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SettlementStatus {
  PENDING
  SETTLED
  FAILED
  REVERSED
}

enum SettlementProvider {
  MOCK
}

enum TeachMode {
  ONLINE
  OFFLINE
  BOTH
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique @db.VarChar(320)
  passwordHash      String     @db.VarChar(255)
  role              UserRole
  name              String     @db.VarChar(191)
  phone             String     @db.VarChar(32)
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?

  parentProfile          ParentProfile?
  tutorProfile           TutorProfile?
  demands                Demand[]                    @relation("ParentDemands")
  parentOrders           Order[]                     @relation("ParentOrders")
  tutorOrders            Order[]                     @relation("TutorOrders")
  refundRequests         Refund[]                    @relation("RefundApplicants")
  lessonFeedbacks        LessonFeedback[]            @relation("TutorLessonFeedbacks")
  parentReviews          Review[]                    @relation("ParentReviews")
  tutorReviews           Review[]                    @relation("TutorReviews")
  tutorSettlements       Settlement[]                @relation("TutorSettlements")
  notifications          Notification[]
  reviewedTutorDocuments TutorVerificationDocument[] @relation("ReviewedTutorDocuments")
  parentConversations    Conversation[]              @relation("ParentConversations")
  tutorConversations     Conversation[]              @relation("TutorConversations")
  sentMessages           Message[]                   @relation("SentMessages")
  supportConversation    SupportConversation?
  supportMessages        SupportMessage[]            @relation("SupportMessages")
}

model ParentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  area          String   @db.VarChar(191)
  addressDetail String   @db.Text
  childInfo     String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutorProfile {
  id                  String              @id @default(cuid())
  userId              String              @unique
  school              String              @db.VarChar(191)
  major               String              @db.VarChar(191)
  grade               String              @db.VarChar(64)
  gender              String              @db.VarChar(32)
  subjects            String              @db.Text
  teachLevels         String              @db.Text
  areas               String              @db.Text
  teachMode           TeachMode
  availableTimes      String              @db.Text
  priceMin            Int
  priceMax            Int
  introduction        String              @db.Text
  experience          String              @db.Text
  certificationStatus CertificationStatus @default(PENDING)
  certificationNote   String?             @db.Text
  rating              Float               @default(0)
  orderCount          Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                  User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationDocuments TutorVerificationDocument[]
}

model TutorVerificationDocument {
  id              String              @id @default(cuid())
  tutorProfileId  String
  type            TutorDocumentType
  storageKey      String              @unique @db.VarChar(512)
  originalName    String              @db.VarChar(255)
  mimeType        String              @db.VarChar(191)
  sizeBytes       Int
  status          TutorDocumentStatus @default(DRAFT)
  rejectionReason String?             @db.Text
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tutorProfile TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("ReviewedTutorDocuments", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tutorProfileId])
  @@index([type])
  @@index([status])
  @@index([reviewedById])
}

model Demand {
  id           String       @id @default(cuid())
  parentId     String
  childGrade   String       @db.VarChar(64)
  subject      String       @db.VarChar(191)
  goal         String       @db.Text
  area         String       @db.VarChar(191)
  teachMode    TeachMode
  expectedTime String       @db.Text
  budgetMin    Int
  budgetMax    Int
  description  String       @db.Text
  status       DemandStatus @default(OPEN)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  parent User    @relation("ParentDemands", fields: [parentId], references: [id], onDelete: Cascade)
  orders Order[]
  conversations Conversation[]

  @@index([parentId])
  @@index([status])
}

model Order {
  id                   String      @id @default(cuid())
  parentId             String
  tutorId              String
  demandId             String?
  subject              String      @db.VarChar(191)
  scheduledTime        DateTime
  teachMode            TeachMode
  location             String      @db.Text
  hours                Float
  hourlyPrice          Int
  totalAmount          Int
  serviceFee           Int
  platformFeeRateBps   Int         @default(500)
  platformFeeAmountFen Int         @default(0)
  tutorNetAmountFen    Int         @default(0)
  status               OrderStatus @default(PENDING_TUTOR_CONFIRM)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  parent         User            @relation("ParentOrders", fields: [parentId], references: [id], onDelete: Cascade)
  tutor          User            @relation("TutorOrders", fields: [tutorId], references: [id], onDelete: Cascade)
  demand         Demand?         @relation(fields: [demandId], references: [id], onDelete: SetNull)
  payment        Payment?
  refunds        Refund[]
  lessonFeedback LessonFeedback?
  review         Review?
  settlement     Settlement?
  conversations  Conversation[]

  @@unique([demandId, tutorId])
  @@index([parentId])
  @@index([tutorId])
  @@index([demandId])
  @@index([status])
}

model Settlement {
  id                   String             @id @default(cuid())
  orderId              String             @unique
  tutorId              String
  provider             SettlementProvider @default(MOCK)
  status               SettlementStatus   @default(PENDING)
  grossAmountFen       Int
  platformFeeRateBps   Int
  platformFeeAmountFen Int
  tutorNetAmountFen    Int
  transactionNo        String?            @unique @db.VarChar(255)
  settledAt            DateTime?
  failureReason        String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tutor User  @relation("TutorSettlements", fields: [tutorId], references: [id], onDelete: Restrict)

  @@index([tutorId])
  @@index([status])
  @@index([settledAt])
}

model Payment {
  id            String    @id @default(cuid())
  orderId       String    @unique
  amount        Int
  provider      String    @default("MOCK") @db.VarChar(64)
  status        String    @default("UNPAID") @db.VarChar(64)
  transactionNo String?   @db.VarChar(255)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id                  String       @id @default(cuid())
  orderId             String
  applicantId         String
  reason              String       @db.VarChar(191)
  description         String       @db.Text
  refundAmount        Int
  previousOrderStatus OrderStatus?
  status              RefundStatus @default(PENDING)
  adminNote           String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  applicant User  @relation("RefundApplicants", fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([applicantId])
  @@index([status])
}

model LessonFeedback {
  id                 String   @id @default(cuid())
  orderId            String   @unique
  tutorId            String
  content            String   @db.Text
  studentPerformance String   @db.Text
  problems           String   @db.Text
  nextSuggestion     String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tutor User  @relation("TutorLessonFeedbacks", fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
}

model Review {
  id                 String   @id @default(cuid())
  orderId            String   @unique
  parentId           String
  tutorId            String
  scorePunctuality   Int
  scoreClarity       Int
  scoreCommunication Int
  scoreAcceptance    Int
  overallScore       Float
  comment            String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parent User  @relation("ParentReviews", fields: [parentId], references: [id], onDelete: Cascade)
  tutor  User  @relation("TutorReviews", fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([tutorId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String    @db.VarChar(255)
  content   String    @db.Text
  type      String    @default("SYSTEM") @db.VarChar(64)
  link      String?   @db.Text
  dedupeKey String?   @unique @db.VarChar(512)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
}

model Conversation {
  id            String             @id @default(cuid())
  parentUserId  String
  tutorUserId   String
  demandId      String
  orderId       String?
  status        ConversationStatus @default(ACTIVE)
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  parent   User      @relation("ParentConversations", fields: [parentUserId], references: [id], onDelete: Cascade)
  tutor    User      @relation("TutorConversations", fields: [tutorUserId], references: [id], onDelete: Cascade)
  demand   Demand    @relation(fields: [demandId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([parentUserId, tutorUserId, demandId])
  @@index([parentUserId])
  @@index([tutorUserId])
  @@index([demandId])
  @@index([orderId])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderUserId   String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model SupportConversation {
  id            String   @id @default(cuid())
  userId        String   @unique
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([lastMessageAt])
}

model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderUserId   String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("SupportMessages", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}
