DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
AUTH_SECRET="replace-with-a-long-random-secret"

# Development uses LOCAL. Production defaults to the private CLOUDBASE provider.
STORAGE_PROVIDER="LOCAL"
PRIVATE_FILE_STORAGE_DRIVER="LOCAL"
PRIVATE_FILE_STORAGE_ROOT=""
CLOUDBASE_ENV_ID=""
CLOUDBASE_REGION=""

# Required only when intentionally resetting the local demo database with seed.
