SEED_DEMO_PASSWORD=""

PLATFORM_FEE_RATE_BPS="500"
SETTLEMENT_PROVIDER="MOCK"

PAYMENT_PROVIDER="MOCK"
PAYMENT_ENABLE_REAL_PROVIDER="false"
